<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
      Name="RTT_T2"
      Manufacturer="flylink-code"
      Version="$(var.ProductVersion)"
      UpgradeCode="8B5F2E1A-3C4D-5E6F-7A8B-9C0D1E2F3A4B"
      Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="已安装更高版本，无法降级安装。" />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="rtt_t2" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="RTT_T2" Level="1">
      <ComponentGroupRef Id="AppFiles" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" />
  </Package>
</Wix>
